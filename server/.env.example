# Server port
PORT=8787

# Comma-separated list of allowed CORS origins.
# Chrome/Edge extensions use chrome-extension://<id>. During dev you can use "*".
CORS_ORIGIN=*

# How often (in minutes) to refresh sources
REFRESH_INTERVAL_MINUTES=30

# Path to the SQLite database file
DATABASE_PATH=./data/news.sqlite

# ---- LLM summarizer (OpenAI-compatible) ----
# Leave LLM_API_KEY empty to disable summarization.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
